---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<Section class="hero">
			<h1>Anything different,<br /> we've got you covered</h1>
			<p>
				At the IEEE  Signal Processing Society CMRIT chapter at CMRIT, we are dedicated to advancing signal processing, image processing, and related technologies.
				We aim to provide knowledge, exposure and indutry level expertise through our events.
			</p>
			</section>

			  <section class="about">
        <h2>Who We Are</h2>
        <p>Started in 2025, we bring students key insights on signal processing and engineering. As part of the IEEE CMRIT student branch, we connect students with current technologies that shape our daily lives.</p>
    </section>

    <section class="what-we-do">
        <h2>What We Do</h2>
        <div class="cards">
            <div class="card">
                <h3>Workshops</h3>
                <p>Hands-on technical workshops and seminars on signal and image processing.</p>
            </div>
            <div class="card">
                <h3>Research</h3>
                <p>Publish research posters and papers with guidance from faculty and industry experts.</p>
            </div>
            <div class="card">
                <h3>Networking</h3>
                <p>Connect students with industry professionals and IEEE members worldwide.</p>
            </div>
        </div>
    </section>
		</main>
		<Footer />
	</body>
</html>
