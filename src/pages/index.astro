---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
    <section class="hero">
        <h1>Anything different,<br />we've got you covered</h1>
        <p>The IEEE Signal Processing Society chapter at CMRIT — advancing signal processing, image processing, and related technologies through workshops, research, and industry exposure.</p>
        <a href="/blog" class="cta-btn">See Latest Updates</a>
    </section>

    <section class="about">
        <h2>Who We Are</h2>
        <p>Started in 2025, we bring students key insights on signal processing and engineering. As part of the IEEE CMRIT student branch, we connect students with current technologies that shape our daily lives.</p>
    </section>

    <section class="what-we-do">
        <h2>What We Do</h2>
        <div class="cards">
            <div class="card">
                <h3>Workshops</h3>
                <p>Hands-on technical workshops and seminars on signal and image processing.</p>
            </div>
            <div class="card">
                <h3>Research</h3>
                <p>Publish research posters and papers with guidance from faculty and industry experts.</p>
            </div>
            <div class="card">
                <h3>Networking</h3>
                <p>Connect students with industry professionals and IEEE members worldwide.</p>
            </div>
        </div>
    </section>
</main>

		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 4em 1em;
		background: black;
		color: white;
		border-radius: 12px;
		margin-bottom: 3em;
	}
	.hero h1 {
		font-size: 2.5em;
		color: white;
		margin-bottom: 0.5em;
	}
	.hero p {
		font-size: 1.1em;
		max-width: 600px;
		margin: 0 auto 1.5em;
	}
	.cta-btn {
		display: inline-block;
		background: #2337ff;
		color: white;
		padding: 0.75em 2em;
		border-radius: 8px;
		text-decoration: none;
		font-weight: bold;
	}
	.about {
		margin-bottom: 3em;
	}
	.cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
	}
	.card {
		background: white;
		border: 1px solid #e5e9f0;
		border-radius: 8px;
		padding: 1.5em;
		box-shadow: 0 2px 8px rgba(0,0,0,0.06);
	}
	.card h3 {
		margin-bottom: 0.5em;
	}
	@media (max-width: 720px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>
